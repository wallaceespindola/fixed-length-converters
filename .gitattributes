# Normalize all text files to LF on commit and checkout.
# Prevents CRLF line endings in source files on Windows,
# which would cause BeanIO / Velocity output to carry \r\n
# and break the 128-char CODA line-length contract.

* text=auto eol=lf

# Explicitly LF for all code and config
*.java     text eol=lf
*.xml      text eol=lf
*.yml      text eol=lf
*.yaml     text eol=lf
*.vm       text eol=lf
*.properties text eol=lf
*.md       text eol=lf
*.json     text eol=lf
*.sh       text eol=lf
Makefile   text eol=lf

# Windows scripts keep CRLF so they work natively in CMD / PowerShell
*.bat      text eol=crlf
*.ps1      text eol=crlf

# Binary — never touch line endings
*.jar      binary
*.class    binary
*.png      binary
*.jpg      binary
*.svg      binary
*.pdf      binary
*.exe      binary
