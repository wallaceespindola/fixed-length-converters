graph LR
    subgraph API["REST API Layer"]
        DC[DomainController]
        BC[BatchController]
        BNC[BenchmarkController]
        ACT[Actuator]
    end
    subgraph Batch["Spring Batch"]
        JS[BatchJobService]
        JOB[bankingFileGenerationJob]
        IR[DomainEntityItemReader]
        IP[FileGenerationItemProcessor]
        IW[FileOutputItemWriter]
        BML[BatchMetricsListener]
    end
    subgraph Strategy["Strategy Layer"]
        SR[StrategyResolver]
        CS["7× CodaStrategy"]
        SS["7× SwiftStrategy"]
    end
    subgraph Parser["Parser Library Wrappers"]
        BIO[BeanIOFormatter]
        FF4J[FixedFormat4JFormatter]
        VL[FixedLengthFormatter]
        BINDY[BindyFormatter]
        CBIO[CamelBeanIOFormatter]
        VEL[VelocityFormatter]
        SBF[SpringBatchFormatter]
    end
    subgraph Domain["Domain Layer"]
        DDG[DomainDataGenerator]
        AR[AccountRepository]
        TR[TransactionRepository]
    end
    subgraph Config["Configuration"]
        BCFG[BatchConfig]
        OAC[OpenApiConfig]
        WC[WebConfig]
    end

