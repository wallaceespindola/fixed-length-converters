%%{init: {'theme': 'base', 'themeVariables': {'lineColor': '#546e7a', 'edgeLabelBackground': '#eceff1'}}}%%
graph LR
    classDef apiStyle      fill:#1565c0,stroke:#0d47a1,color:#fff
    classDef batchStyle    fill:#2e7d32,stroke:#1b5e20,color:#fff
    classDef strategyStyle fill:#6a1b9a,stroke:#4a148c,color:#fff
    classDef parserStyle   fill:#006064,stroke:#004d40,color:#fff
    classDef domainStyle   fill:#e65100,stroke:#bf360c,color:#fff
    classDef configStyle   fill:#37474f,stroke:#263238,color:#fff

    subgraph API["🌐  REST API Layer"]
        DC[DomainController]
        BC[BatchController]
        BNC[BenchmarkController]
        ACT[Actuator]
    end

    subgraph Batch["⚙  Spring Batch"]
        JS[BatchJobService]
        JOB[bankingFileGenerationJob]
        IR[DomainEntityItemReader]
        IP[FileGenerationItemProcessor]
        IW[FileOutputItemWriter]
        BML[BatchMetricsListener]
    end

    subgraph Strategy["🔀  Strategy Layer"]
        SR[StrategyResolver]
        CS["7× CodaStrategy"]
        SS["7× SwiftStrategy"]
    end

    subgraph Parser["📦  Parser Library Wrappers"]
        BIO[BeanIOFormatter]
        FF4J[FixedFormat4JFormatter]
        VL[FixedLengthFormatter]
        BINDY[BindyFormatter]
        CBIO[CamelBeanIOFormatter]
        VEL[VelocityFormatter]
        SBF[SpringBatchFormatter]
    end

    subgraph Domain["🗄  Domain Layer"]
        DDG[DomainDataGenerator]
        AR[AccountRepository]
        TR[TransactionRepository]
    end

    subgraph Config["⚙  Configuration"]
        BCFG[BatchConfig]
        OAC[OpenApiConfig]
        WC[WebConfig]
    end

    DC  --> DDG
    BC  --> JS
    JS  --> JOB
    JOB --> IR
    JOB --> IP
    JOB --> IW
    JOB --> BML
    IP  --> SR
    SR  --> CS
    SR  --> SS
    CS  --> BIO & FF4J & VL & BINDY & CBIO & VEL & SBF
    SS  --> BIO & FF4J & VL & BINDY & CBIO & VEL & SBF
    IR  --> TR
    DDG --> AR
    DDG --> TR

    class DC,BC,BNC,ACT apiStyle
    class JS,JOB,IR,IP,IW,BML batchStyle
    class SR,CS,SS strategyStyle
    class BIO,FF4J,VL,BINDY,CBIO,VEL,SBF parserStyle
    class DDG,AR,TR domainStyle
    class BCFG,OAC,WC configStyle
