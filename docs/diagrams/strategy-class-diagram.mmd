classDiagram
    class FileGenerationStrategy {
        <<interface>>
        +generate(transactions, accounts) String
        +parse(fileContent) List~Transaction~
        +getFileType() FileType
        +getLibrary() Library
        +strategyKey() String
    }

    class AbstractCodaStrategy {
        <<abstract>>
        +getFileType() FileType.CODA
        +generate(transactions, accounts) String
        +parse(fileContent) List~Transaction~
        #formatRecords(records) String
        #parseRecords(content) List~CodaRecord~
        #buildHeader(account) CodaRecord
        #buildMovement(tx, account) CodaRecord
        #buildTrailer(transactions) CodaRecord
    }

    class AbstractSwiftStrategy {
        <<abstract>>
        +getFileType() FileType.SWIFT
        +generate(transactions, accounts) String
        +parse(fileContent) List~Transaction~
        #formatRecords(records) String
        #parseRecords(content) List~SwiftMtRecord~
    }

    class CodaBeanIOStrategy {
        -formatter BeanIOFormatter
        +getLibrary() Library.BEANIO
        #formatRecords(records) String
        #parseRecords(content) List~CodaRecord~
    }

    class CodaFixedFormat4JStrategy {
        -formatter FixedFormat4JFormatter
        +getLibrary() Library.FIXFORMAT4J
