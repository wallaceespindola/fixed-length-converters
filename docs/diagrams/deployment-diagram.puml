@startuml deployment-diagram
title Deployment Topology

skinparam backgroundColor #fafafa
skinparam ShadowingEnabled false
skinparam RoundCorner 6
skinparam ArrowColor #546e7a
skinparam defaultFontName Arial
skinparam defaultFontSize 12

skinparam node {
    BackgroundColor #eceff1
    BorderColor #37474f
    FontColor #263238
    FontStyle bold
}

skinparam component {
    BackgroundColor #2e7d32
    BorderColor #1b5e20
    FontColor #ffffff
}

skinparam artifact {
    BackgroundColor #2e7d32
    BorderColor #1b5e20
    FontColor #ffffff
}

skinparam folder {
    BackgroundColor #eceff1
    BorderColor #37474f
    FontColor #263238
}

node "Developer Machine" #e8f5e9 ##2e7d32 {
    node "JVM (Java 21)" #e8f5e9 ##2e7d32 {
        artifact "fixed-length-converters.jar" as JAR #2e7d32 ##1b5e20
        component "Spring Boot\nlocalhost:8080" as APP #2e7d32 ##1b5e20
        component "H2 In-Memory DB\nbankingdb" as H2 #37474f ##263238
        component "Web UI (HTML/CSS/JS)\n/static/index.html" as SPA #e65100 ##bf360c
    }
    folder "output/" as OUT #eceff1 ##37474f
}

node "Web Browser" #e3f2fd ##1565c0 {
    component "Browser" as BR #1565c0 ##0d47a1
}

node "GitHub Actions" #e8f5e9 ##2e7d32 {
    component "build.yml\nmvn install -DskipTests" as BUILD #2e7d32 ##1b5e20
    component "test.yml\nmvn verify + JaCoCo" as TEST #2e7d32 ##1b5e20
    component "benchmark.yml\nJMH benchmarks" as BENCH #2e7d32 ##1b5e20
    component "codeql.yml\nSecurity scan" as CQL #2e7d32 ##1b5e20
    component "release.yml\nGitHub Release" as REL #2e7d32 ##1b5e20
}

JAR --> APP
APP <--> H2 : JDBC
APP --> SPA : serve static
APP --> OUT : write *.txt
BR --> APP : HTTP REST /api/*\nHTTP /actuator/*
APP --> SPA : fallback to index.html

BUILD --> JAR : produces
TEST --> JAR : tests
REL --> JAR : attaches to release
@enduml
