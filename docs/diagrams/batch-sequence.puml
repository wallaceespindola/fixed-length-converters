@startuml batch-sequence
title Spring Batch File Generation — Execution Sequence

skinparam backgroundColor #fafafa
skinparam ShadowingEnabled false
skinparam defaultFontName Arial
skinparam defaultFontSize 12
skinparam ArrowColor #546e7a

skinparam actor {
    BackgroundColor #e65100
    BorderColor #bf360c
    FontColor #ffffff
}

skinparam participant {
    BackgroundColor #f5f5f5
    BorderColor #546e7a
    FontColor #263238
}

skinparam database {
    BackgroundColor #37474f
    BorderColor #263238
    FontColor #ffffff
}

skinparam collections {
    BackgroundColor #37474f
    BorderColor #263238
    FontColor #ffffff
}

skinparam note {
    BackgroundColor #fff8f5
    BorderColor #e65100
    FontColor #263238
}

skinparam sequence {
    GroupBackgroundColor #e8f5e9
    GroupBorderColor #2e7d32
    GroupFontColor #1b5e20
    DividerBackgroundColor #1565c0
    DividerFontColor #ffffff
    DividerBorderColor #0d47a1
    LifeLineBorderColor #546e7a
    LifeLineBackgroundColor #f5f5f5
    BoxBackgroundColor #fafafa
    BoxBorderColor #546e7a
}

actor Frontend #e65100

participant DomainController #1565c0
participant DomainDataGenerator #1565c0
participant BatchController #1565c0
participant BatchJobService #2e7d32
participant JobLauncher #2e7d32
participant "bankingFileGenerationJob" as Job #2e7d32
participant DomainEntityItemReader as Reader #2e7d32
participant FileGenerationItemProcessor as Processor #2e7d32
participant StrategyResolver #6a1b9a
participant "FileGenerationStrategy\n(e.g. CodaBeanIOStrategy)" as Strategy #006064
participant FileOutputItemWriter as Writer #2e7d32
participant BatchMetricsListener as Listener #2e7d32
database "H2 Database" as DB #37474f
collections "output/ (filesystem)" as FS #37474f

== Step 1: seed sample data (LOW or HIGH load profile) ==
Frontend -> DomainController : POST /api/domain/generate\n?loadProfile=LOW|HIGH
DomainController -> DomainDataGenerator : generate(LoadProfile)
DomainDataGenerator -> DB : save accounts + transactions + statements
DomainDataGenerator --> DomainController : GenerationResult
DomainController --> Frontend : GenerateDomainResponse

== Step 2: trigger a Spring Batch job per (fileType × library) ==
Frontend -> BatchController : POST /api/batch/generate\n{fileType, library}
BatchController -> BatchJobService : launch(fileType, library)
BatchJobService -> JobLauncher : run(job, params)
JobLauncher -> Job : execute()
Job -> Listener : beforeJob()

loop each chunk of 100 transactions
    Job -> Reader : read() → Transaction
    Reader -> DB : findAll()
    DB --> Reader : List<Transaction>

    Job -> Processor : process(transaction)
    Processor -> StrategyResolver : resolve(fileType, library)
    StrategyResolver --> Processor : FileGenerationStrategy
    Processor -> Strategy : generate([transaction], accounts)
    Strategy --> Processor : formatted string

    Job -> Writer : write(Chunk<String>)
end

Writer -> FS : write output file
Writer -> Job : @AfterStep → COMPLETED

Job -> Listener : afterJob()
Listener -> DB : save BenchmarkMetrics

Job --> BatchJobService : JobExecution
BatchJobService --> BatchController : BatchJobResult
BatchController --> Frontend : BatchJobResponse\n{fileContent, fileName, status, timestamp}
@enduml
